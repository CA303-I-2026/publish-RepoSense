Miguel11"},"content":"title: \"Bitacora_1\"","isFullCredit":false},{"lineNumber":3,"author":{"gitId":"JoseMiguel11"},"content":"format: ","isFullCredit":false},{"lineNumber":4,"author":{"gitId":"JoseMiguel11"},"content":" pdf: ","isFullCredit":false},{"lineNumber":5,"author":{"gitId":"JoseMiguel11"},"content":"   papersize: letter","isFullCredit":false},{"lineNumber":6,"author":{"gitId":"JoseMiguel11"},"content":"   documentclass: article","isFullCredit":false},{"lineNumber":7,"author":{"gitId":"JoseMiguel11"},"content":"   lang: es-CR","isFullCredit":false},{"lineNumber":8,"author":{"gitId":"JoseMiguel11"},"content":"   titlepage: true","isFullCredit":false},{"lineNumber":9,"author":{"gitId":"JoseMiguel11"},"content":"   toc: true","isFullCredit":false},{"lineNumber":10,"author":{"gitId":"JoseMiguel11"},"content":"   toc-title: \"Índice\"","isFullCredit":false},{"lineNumber":11,"author":{"gitId":"JoseMiguel11"},"content":"   toccolor: \"black\"","isFullCredit":false},{"lineNumber":12,"author":{"gitId":"JoseMiguel11"},"content":"   fontsize: \"11pt\"","isFullCredit":false},{"lineNumber":13,"author":{"gitId":"JoseMiguel11"},"content":"   mainfont: Times New Roman","isFullCredit":false},{"lineNumber":14,"author":{"gitId":"JoseMiguel11"},"content":"   urlcolor: \"blue\"","isFullCredit":false},{"lineNumber":15,"author":{"gitId":"JoseMiguel11"},"content":"   number-sections: true","isFullCredit":false},{"lineNumber":16,"author":{"gitId":"JoseMiguel11"},"content":"   margin-left: \"2.54cm\"","isFullCredit":false},{"lineNumber":17,"author":{"gitId":"JoseMiguel11"},"content":"   margin-right: \"2.54cm\"","isFullCredit":false},{"lineNumber":18,"author":{"gitId":"JoseMiguel11"},"content":"   margin-top: \"2.54cm\"","isFullCredit":false},{"lineNumber":19,"author":{"gitId":"JoseMiguel11"},"content":"   margin-bottom: \"2.54cm\"","isFullCredit":false},{"lineNumber":20,"author":{"gitId":"JoseMiguel11"},"content":"   header-includes:","isFullCredit":false},{"lineNumber":21,"author":{"gitId":"JoseMiguel11"},"content":"            - \\usepackage{indentfirst}","isFullCredit":false},{"lineNumber":22,"author":{"gitId":"JoseMiguel11"},"content":"            - \\setlength{\\parindent}{1.27cm}   ","isFullCredit":false},{"lineNumber":23,"author":{"gitId":"JoseMiguel11"},"content":"---","isFullCredit":false},{"lineNumber":24,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":25,"author":{"gitId":"JoseMiguel11"},"content":"# Parte 1 Planificación","isFullCredit":false},{"lineNumber":26,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":27,"author":{"gitId":"JoseMiguel11"},"content":"## Pregunta de investigación","isFullCredit":false},{"lineNumber":28,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":29,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":30,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":31,"author":{"gitId":"JoseMiguel11"},"content":"### Argumentación a través de datos","isFullCredit":false},{"lineNumber":32,"author":{"gitId":"JoseMiguel11"},"content":"#### Fuente de información","isFullCredit":false},{"lineNumber":33,"author":{"gitId":"JoseMiguel11"},"content":"Los datos fueron obtenidos de la Universidad de Valencia a través de la página Mendeley Data en la cual se descargaron dos archivos tipo csv y uno tipo excel, el primer archivo se titula “Descriptive of the variables.xlsx” en el cual se encuentra la descripción de cada una de las variables/columnas de los datos, el segundo archivo se titula “Motor vehicle insurance data.csv”, este archivo posee la información de las pólizas de seguros y el tercer archivo se titula “sample type claim.csv” el cual posee información detallada de los siniestros, donde se indica el ID, el monto total de reclamos en un año, el costo de una parte de los reclamos y la categorización del tipo de reclamo.","isFullCredit":false},{"lineNumber":34,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":35,"author":{"gitId":"JoseMiguel11"},"content":"#### Contexto temporal y espacial de los datos","isFullCredit":false},{"lineNumber":36,"author":{"gitId":"JoseMiguel11"},"content":"Los datos contemplan la información de pólizas de seguros de autos desde 1980 hasta el 2017 según la fecha de inicio de pólizas y del 2015 al 2019 según las fechas de renovaciones; además de esto, hay información de los siniestros para los años del 2016 al 2018. El contexto espacial corresponde a la ciudad de Valencia, España. ","isFullCredit":false},{"lineNumber":37,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":38,"author":{"gitId":"JoseMiguel11"},"content":"#### Facilidad de obtener la infromación","isFullCredit":false},{"lineNumber":39,"author":{"gitId":"JoseMiguel11"},"content":"Como se mencionó anteriormente, los datos se extrajeron de la página “Mendeley Data”, para descargar los datos no se requiere solicitarlos, cualquier persona puede descargarlos gratuitamente; sin embargo, algunas columnas como “length” y “weigth” poseen algunos NA, además, las columnas que poseen fechas, como “Date_start_contract” y otras, vienen como tipo character y no como tipo date por lo que se debe hacer la transformación de tipo character a tipo date.","isFullCredit":false},{"lineNumber":40,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":41,"author":{"gitId":"JoseMiguel11"},"content":"#### Población de estudio","isFullCredit":false},{"lineNumber":42,"author":{"gitId":"JoseMiguel11"},"content":"La población estudio de esta investigación corresponde a los asegurados que posee al menos una póliza de seguro de vehículos en la ciudad de Valencia; donde se contemplan motocicletas, furgonetas, turismos (automóviles de 4 a 5 asientos) y vehículos agrícolas; ya sean de zonas rurales o urbanas; con información de los siniestros que van del 2016 al 2018.","isFullCredit":false},{"lineNumber":43,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":44,"author":{"gitId":"JoseMiguel11"},"content":"#### Muestra observada","isFullCredit":false},{"lineNumber":45,"author":{"gitId":"JoseMiguel11"},"content":"La muestra observada posee un total de 105555 observaciones, de las cuales 53502 corresponden a identificaciones únicas en las que cada una es un asegurado distinto; además se tienen 30 columnas en total, además posee asegurados con y sin siniestros.","isFullCredit":false},{"lineNumber":46,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":47,"author":{"gitId":"JoseMiguel11"},"content":"#### Unidad estadística o individuos","isFullCredit":false},{"lineNumber":48,"author":{"gitId":"JoseMiguel11"},"content":"La unidad estadística es póliza por año, donde cada fila de los datos corresponde a una anualidad del contrato del asegurado; esto hace que un mismo asegurado pueda aparecer más de una vez en las filas, por eso se pasó de 105555 observaciones totales a 53502 únicas; como puede aparecer múltiples veces, da la posibilidad de ver la evolución de la póliza a lo largo del tiempo. Mientras que en el archivo “sample type claim.csv”, la unidad estadística es el tipo de siniestro para cada individuo.","isFullCredit":false},{"lineNumber":49,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":50,"author":{"gitId":"JoseMiguel11"},"content":"#### Descripción de las variales de la tabla","isFullCredit":false},{"lineNumber":51,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":52,"author":{"gitId":"JoseMiguel11"},"content":"##### Motor vehicle insurance data","isFullCredit":false},{"lineNumber":53,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":54,"author":{"gitId":"JoseMiguel11"},"content":"-   **ID** (Identificador): Corresponde al número de identificación interna asignada a cada contrato anual de un asegurado","isFullCredit":false},{"lineNumber":55,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":56,"author":{"gitId":"JoseMiguel11"},"content":"-   **Date_start_contract** (Fecha de inicio del contrato): Fecha de inicio del contrato del asegurado, tiene formato día/mes/año","isFullCredit":false},{"lineNumber":57,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":58,"author":{"gitId":"JoseMiguel11"},"content":"-   **Date_last_renewal** (Fecha de la última renovación): Fecha de la última renovación del contrato, tiene formato día/mes/año","isFullCredit":false},{"lineNumber":59,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":60,"author":{"gitId":"JoseMiguel11"},"content":"-   **Date_next_renewal** (Fecha de la próxima renovación): Fecha de la próxima renovación del contrato, tiene formato día/mes/año","isFullCredit":false},{"lineNumber":61,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":62,"author":{"gitId":"JoseMiguel11"},"content":"-   **Distribution_channel** (Canal de distribución): Clasifica el canal a través del cual se contrató la póliza. 0 si fue un Agente y 1 para Corredores de seguros.","isFullCredit":false},{"lineNumber":63,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":64,"author":{"gitId":"JoseMiguel11"},"content":"-   **Date_birth** (Fecha de nacimiento): Fecha de nacimiento del asegurado declarada en la póliza, tiene formato día/mes/año.","isFullCredit":false},{"lineNumber":65,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":66,"author":{"gitId":"JoseMiguel11"},"content":"- **Date_driving_licence** (Fecha de la licencia de conducir): Fecha de expedición del permiso de conducir de la persona asegurada, tiene formato día/mes/año.","isFullCredit":false},{"lineNumber":67,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":68,"author":{"gitId":"JoseMiguel11"},"content":"- **Seniority** (Antigüedad): Número total de años que el asegurado ha estado asociado con la entidad aseguradora.","isFullCredit":false},{"lineNumber":69,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":70,"author":{"gitId":"JoseMiguel11"},"content":"- **Policies_in_force** (Pólizas en vigencia): Número total de pólizas que el asegurado posee con la entidad aseguradora en el periodo de referencia.","isFullCredit":false},{"lineNumber":71,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":72,"author":{"gitId":"JoseMiguel11"},"content":"- **Max_policies** (Máximo de pólizas): Número máximo de pólizas que el asegurado ha tenido alguna vez en vigor con la entidad aseguradora.","isFullCredit":false},{"lineNumber":73,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":74,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":75,"author":{"gitId":"JoseMiguel11"},"content":"- **Max_products** (Productos máximos): Número máximo de productos que el asegurado ha mantenido simultáneamente en un momento dado.","isFullCredit":false},{"lineNumber":76,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":77,"author":{"gitId":"JoseMiguel11"},"content":"- **Lapse** (Cancelación): Número de pólizas que el cliente ha cancelado o se le han cancelado por impago en el año de vencimiento actual, excluyendo aquellas que han sido reemplazadas por otra póliza.","isFullCredit":false},{"lineNumber":78,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":79,"author":{"gitId":"JoseMiguel11"},"content":"- **Date_lapse** (Fecha de cancelación): Fecha de cancelación; fecha de terminación del contrato, tiene formato día/mes/año","isFullCredit":false},{"lineNumber":80,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":81,"author":{"gitId":"JoseMiguel11"},"content":"- **Payment** (Método de pago): Último método de pago de la póliza de referencia. El 1 representa un proceso administrativo semestral y 0 indica un método de pago anual.","isFullCredit":false},{"lineNumber":82,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":83,"author":{"gitId":"JoseMiguel11"},"content":"- **Premium** (Prima): Monto de la prima neta asociada a la póliza durante el año en curso.","isFullCredit":false},{"lineNumber":84,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":85,"author":{"gitId":"JoseMiguel11"},"content":"- **Cost_claims_year** (Costo de siniestro del año): Costo total de los siniestros de la póliza de seguro durante el año en curso.","isFullCredit":false},{"lineNumber":86,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":87,"author":{"gitId":"JoseMiguel11"},"content":"- **N_claims_year** (Número de siniestro en el año): Número total de siniestros ocurridos para la póliza de seguro durante el año en curso.","isFullCredit":false},{"lineNumber":88,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":89,"author":{"gitId":"JoseMiguel11"},"content":"- **N_claims_history** (Número de siniestros histórico): Número total de siniestros declarados durante toda la vigencia de la póliza de seguro.","isFullCredit":false},{"lineNumber":90,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":91,"author":{"gitId":"JoseMiguel11"},"content":"- **R_Claims_history** (Ratio de siniestros histórico): Ratio del número de siniestros declarados para la póliza específica con respecto a la duración total (en años completos) de la póliza en vigor.","isFullCredit":false},{"lineNumber":92,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":93,"author":{"gitId":"JoseMiguel11"},"content":"- **Type_risk** (Tipo de riesgo): Tipo de riesgo asociado a la póliza. Cada valor corresponde a un tipo de riesgo específico: 1 para motocicletas, 2 para furgonetas, 3 para turismos y 4 para vehículos agrícolas.","isFullCredit":false},{"lineNumber":94,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":95,"author":{"gitId":"JoseMiguel11"},"content":"- **Area** (Zona): Representa la zona de circulación del vehículo. 0 para rural y 1 para urbano (más de 30.000 habitantes) en términos de condiciones de tráfico.","isFullCredit":false},{"lineNumber":96,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":97,"author":{"gitId":"JoseMiguel11"},"content":"- **Second_driver** (Segundo conductor): 1 si hay varios conductores habituales declarados, o 0 si solo se declara un conductor.","isFullCredit":false},{"lineNumber":98,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":99,"author":{"gitId":"JoseMiguel11"},"content":"- **Year_matriculation** (Año de matriculación): Año de matriculación del vehículo.","isFullCredit":false},{"lineNumber":100,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":101,"author":{"gitId":"JoseMiguel11"},"content":"- **Power** (Potencia): Potencia del vehículo medida en caballos de fuerza.","isFullCredit":false},{"lineNumber":102,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":103,"author":{"gitId":"JoseMiguel11"},"content":"- **Cylinder_capacity** (Capacidad de cilindrada): Cilindrada del vehículo.","isFullCredit":false},{"lineNumber":104,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":105,"author":{"gitId":"JoseMiguel11"},"content":"- **Value_vehicle** (Valor del vehículo): Valor de mercado del vehículo al 31 de diciembre del 2019.","isFullCredit":false},{"lineNumber":106,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":107,"author":{"gitId":"JoseMiguel11"},"content":"- **N_doors** (Número de puertas): Número total de puertas del vehículo.","isFullCredit":false},{"lineNumber":108,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":109,"author":{"gitId":"JoseMiguel11"},"content":"- **Type_fuel** (Tipo de combustible): Tipo específico de combustible utilizado para el vehículo. P para Gasolina y D para Diésel.","isFullCredit":false},{"lineNumber":110,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":111,"author":{"gitId":"JoseMiguel11"},"content":"- **Length** (Longitud): Longitud en metros del vehículo.","isFullCredit":false},{"lineNumber":112,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":113,"author":{"gitId":"JoseMiguel11"},"content":"- **Weight** (Peso): Peso en kilogramos del vehículo.","isFullCredit":false},{"lineNumber":114,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":115,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":116,"author":{"gitId":"JoseMiguel11"},"content":"##### Sample type claim","isFullCredit":false},{"lineNumber":117,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":118,"author":{"gitId":"JoseMiguel11"},"content":"- **ID** (Identificador): Mismo identificador que en el archivo principal. Permite vincular cada siniestro con la póliza asociada.","isFullCredit":false},{"lineNumber":119,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":120,"author":{"gitId":"JoseMiguel11"},"content":"- **Cost_claims_year** (Costo de siniestros del año): Costo total de los siniestros de la póliza durante el año en curso.","isFullCredit":false},{"lineNumber":121,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":122,"author":{"gitId":"JoseMiguel11"},"content":"- **Cost_claims_by_type** (Costo de siniestros por tipo): Costo asociado a un tipo específico de reclamo dentro del siniestro.","isFullCredit":false},{"lineNumber":123,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false},{"lineNumber":124,"author":{"gitId":"JoseMiguel11"},"content":"- **Claims_type** (Tipo de siniestro): Clasificación del tipo de reclamo como: asistencia en viaje, rotura de lunas, reclamación, negligencia, robo, incendio, lesiones, etc.","isFullCredit":false},{"lineNumber":125,"author":{"gitId":"JoseMiguel11"},"content":"","isFullCredit":false}],"authorContributionMap":{"JoseMiguel11":125}}]
